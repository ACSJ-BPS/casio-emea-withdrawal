<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="casio_withdrawal" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
            <class>separator-top</class>
            <label>Casio Withdrawal</label>
            <tab>casio</tab>
            <resource>Casio_POT::config</resource>
            <group id="configuration" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Configuration</label>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="shipping_return_cron" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Shipment Return schedule</label>
                    <comment><![CDATA[
                                <pre>
                                * * * * *
                                | | | | |
                                | | | | +---- Day of the Week   (range: 1-7, 1 standing for Monday)
                                | | | +------ Month of the Year (range: 1-12)
                                | | +-------- Day of the Month  (range: 1-31)
                                | +---------- Hour              (range: 0-23)
                                +------------ Minute            (range: 0-59)
                                Example: 0 0 * * * Daily at midnight
                                </pre>
                            ]]></comment>
                </field>
                <field id="interval" translate="label" type="text" sortOrder="1000" showInWebsite="1" showInDefault="1" canRestore="1">
                    <label>Customer Order Withdrawal Interval:</label>
                    <comment><![CDATA[Enter values will be consider in days.(If left empty, default is 45 days)]]></comment>
                    <validate>validate-no-special-chars</validate>
                </field>
            </group>
            <group id="piano_email" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Withdrawal submission emails piano</label>
                <field id="enable" translate="label" type="select" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="email_sender" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Sender</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Identity</source_model>
                    <depends>
                        <field id="casio_withdrawal/piano_email/enable">1</field>
                    </depends>
                </field>
                <field id="email_template" translate="label" type="select" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                    <depends>
                        <field id="casio_withdrawal/piano_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copyto" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy To</label>
                    <comment>Comma-separated.</comment>
                    <validate>validate-emails</validate>
                    <depends>
                        <field id="casio_withdrawal/piano_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copy_method" translate="label" type="select" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy Method</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Method</source_model>
                    <depends>
                        <field id="casio_withdrawal/piano_email/enable">1</field>
                    </depends>
                </field>
            </group>
            <group id="submission_email" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Withdrawal submission Email</label>
                <field id="enable" translate="label" type="select" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="email_sender" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Sender</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Identity</source_model>
                    <depends>
                        <field id="casio_withdrawal/withdrawal_submission_email/enable">1</field>
                    </depends>
                </field>
                <field id="email_template" translate="label" type="select" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                    <depends>
                        <field id="casio_withdrawal/withdrawal_submission_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copyto" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy To</label>
                    <comment>Comma-separated.</comment>
                    <validate>validate-emails</validate>
                    <depends>
                        <field id="casio_withdrawal/withdrawal_submission_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copy_method" translate="label" type="select" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy Method</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Method</source_model>
                    <depends>
                        <field id="casio_withdrawal/withdrawal_submission_email/enable">1</field>
                    </depends>
                </field>
            </group>
            <group id="confirmation_email" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Withdrawal Confirmation Email</label>
                <field id="enable" translate="label" type="select" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="email_sender" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Sender</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Identity</source_model>
                    <depends>
                        <field id="casio_withdrawal/confirmation_email/enable">1</field>
                    </depends>
                </field>
                <field id="email_template" translate="label" type="select" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                    <depends>
                        <field id="casio_withdrawal/confirmation_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copyto" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy To</label>
                    <comment>Comma-separated.</comment>
                    <validate>validate-emails</validate>
                    <depends>
                        <field id="casio_withdrawal/confirmation_email/enable">1</field>
                    </depends>
                </field>
                <field id="send_email_copy_method" translate="label" type="select" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Send Email Copy Method</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Method</source_model>
                    <depends>
                        <field id="casio_withdrawal/confirmation_email/enable">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
