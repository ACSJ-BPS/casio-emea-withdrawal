  <schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order">
        <column xsi:type="int" name="withdrawal_order_status" default="0" padding="11" unsigned="false" nullable="true" comment="Withdrawal Order Status" />
    </table>
    <table name="sales_order_item">
        <column xsi:type="int" name="withdrawal_item_status" default="0" padding="11" unsigned="false" nullable="true" comment="Withdrawal Item Status" />
        <column xsi:type="int" name="withdrawal_qty" default="0" padding="11" unsigned="false" nullable="true" comment="Withdrawal Quantity" />
        <column xsi:type="int" name="withdrawal_item_reason" default="0" padding="11" unsigned="false" nullable="true" comment="Withdrawal Item Reason" />
    </table>
  </schema>

